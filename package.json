{
  "name": "healpix-ts",
  "version": "1.0.0",
  "description": "HEALPix (Hierarchical Equal Area isoLatitude Pixelization) implementation in TypeScript",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c --watch",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "healpix",
    "spherical",
    "projection",
    "astronomy",
    "geospatial",
    "pixelization",
    "sphere",
    "coordinates"
  ],
  "author": {
    "name": "Daniel da Silva",
    "email": "daniel@develpmentseed.org",
    "url": "https://github.com/danielfdsilva"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/developmentseed/healpix-ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "rollup": "^4.57.1",
    "rollup-plugin-dts": "^6.3.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  }
}
